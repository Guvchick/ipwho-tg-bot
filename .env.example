BOT_TOKEN=your_telegram_bot_token_here
IPWHO_ACCESS_KEY=your_ipwho_access_key_here

# Optional: ipinfo.io token for higher limits.
# IPINFO_TOKEN=your_ipinfo_token_here

# Optional: Censys Search API credentials. If omitted, bot still adds Censys links.
# CENSYS_API_ID=your_censys_api_id
# CENSYS_API_SECRET=your_censys_api_secret

# Queue and subscription pacing.
# QUEUE_SIZE=128
# GEO_CONCURRENCY=8
# SUB_MESSAGE_DELAY_MS=450
# DNS_CACHE_TTL_MINUTES=30
# GEO_CACHE_TTL_MINUTES=10

# HWID is auto-detected from /etc/machine-id (Linux) or MAC address.
# Set manually to override:
# HWID=your_custom_hwid_here
